[core]
	autocrlf = input
	editor = vim
	filemode = false
[credential]
	helper = store
[alias]
	br = branch
	st = status
	co = checkout
	ci = commit
	tree = log --graph --all --abbrev-commit --decorate --date=relative --pretty=format:'%C(auto)%h%Creset %s %Cgreen(%cr) %Cblue<%an>%Creset %C(auto)%d%Creset'
[init]
	defaultBranch = main
[fetch]
	prune = true
